# ============================================================
# Regime-Switching Risk-Parity Crypto Index Vault
# Environment Configuration
# ============================================================

# -- Ethereum Sepolia Testnet --
# Get free RPC URL from: https://www.alchemy.com/
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Testnet deployer wallet private key (NEVER use mainnet key)
# Export from MetaMask: Settings > Security > Export Private Key
DEPLOYER_PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY_HERE

# Get free API key from: https://etherscan.io/register
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# -- Data Sources --
# Binance public API: NO key required for OHLCV data (ccxt uses public endpoints)
# CoinGecko: NO key required for market cap data (free tier)
# All ML pipeline data is fetched from public APIs — no additional keys needed
